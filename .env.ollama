OPENAI_API_KEY=dummy
# OpenAI-compatible local endpoint exposed by Ollama
OPENAI_BASE_URL=http://localhost:11434/v1

# Optional OpenRouter-only settings (ignored for local Ollama usage)
# OPENROUTER_HTTP_REFERER=https://example.com
# OPENROUTER_APP_TITLE=Custerion Collection
# OPENROUTER_PROVIDER_PREFERENCES_JSON={"require_parameters": true, "zdr": true}
# OPENROUTER_GROUNDED_RESEARCH_MODEL=openrouter/perplexity/sonar

# Primary and fallback models via LiteLLM Ollama provider
MODEL_NAME=ollama/qwen2.5:14b-instruct
MODEL_FALLBACKS=ollama/llama3.1:8b-instruct,ollama/mistral:7b-instruct

# Optional dedicated model for HTML report generation
MODEL_NAME_HTML_REPORTER=ollama/qwen2.5:14b-instruct
# Optional dedicated model for final long-form article synthesis
MODEL_NAME_ARTICLE_WRITER=ollama/qwen2.5:14b-instruct
# Optional dedicated smart model for subtitle+report commentary planning
MODEL_NAME_COMMENTARY_PLANNER=ollama/qwen2.5:14b-instruct
# App-controlled planner objective for generating spoiler-aware timed commentary
COMMENTARY_PLANNING_GOAL=Generate a spoiler-aware audio commentary track from subtitle cues and report insights; align beats to subtitle-grounded context, apply a short reveal delay, keep pacing smooth, and avoid dense trivia clustering.

HTML_REPORT_RETRY_ATTEMPTS=2
HTML_REPORT_RETRY_DELAY_SECONDS=1.5

# Optional local TTS configuration (Kokoro ONNX, English-only)
TTS_DEFAULT_VOICE=af_sarah
TTS_ENGLISH_VOICES=af_sarah,af_heart
TTS_CACHE_DIR=./data/tts-cache
KOKORO_MODEL_URL=https://github.com/thewh1teagle/kokoro-onnx/releases/download/model-files-v1.0/kokoro-v1.0.onnx
KOKORO_VOICES_URL=https://github.com/thewh1teagle/kokoro-onnx/releases/download/model-files-v1.0/voices-v1.0.bin

# Optional per-role model overrides
# MODEL_NAME_TECHNICAL_DIRECTOR=
# MODEL_NAME_SCRIPT_EDITOR=
# MODEL_NAME_TRIVIA_RESEARCHER=

# Optional live LLM test controls
# RUN_LLM_LIVE_TESTS=0
# LLM_LIVE_TEST_MODEL=
# LLM_LIVE_TEST_MAX_CALLS_PER_DAY=3
# LLM_LIVE_TEST_COOLDOWN_SECONDS=20
# LLM_LIVE_TEST_QUOTA_PATH=

DATA_DIR=./data
PROCESS_MODE=hierarchical
HTTP_RETRY_COUNT=2
HTTP_RETRY_BACKOFF_SECONDS=0.4
FRONTEND_ORIGIN=http://localhost:4173

# Jellyfin adapter
JELLYFIN_URL=
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=

# Approved external providers
TMDB_API_KEY=
YOUTUBE_API_KEY=
